\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Forecast-side winners need not remain deployed winners. Each cell reports the forecast-side winner and deployed winner under one fixed interface, together with the number of seeds in which the forecast-selected model is deployed-suboptimal. Event-micro and Traffic-Hourly provide forecasting-native evidence; inventory provides operational corroboration at moderate-to-high friction. The inventory zero-friction cell is marked as mixed and is not used as headline corroboration.}}{2}{figure.2}\protected@file@percent }
\newlabel{fig:q2-required}{{2}{2}{Forecast-side winners need not remain deployed winners. Each cell reports the forecast-side winner and deployed winner under one fixed interface, together with the number of seeds in which the forecast-selected model is deployed-suboptimal. Event-micro and Traffic-Hourly provide forecasting-native evidence; inventory provides operational corroboration at moderate-to-high friction. The inventory zero-friction cell is marked as mixed and is not used as headline corroboration}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Event-micro Q2 evidence. Under a fixed thresholding interface, the forecast-side winner remains Reactive sharp, but the deployed winner shifts as switching friction increases. The forecast-selected model becomes recurrently deployed-suboptimal at moderate and high friction.}}{2}{table.1}\protected@file@percent }
\newlabel{tab:event-micro-selection-drift-main}{{1}{2}{Event-micro Q2 evidence. Under a fixed thresholding interface, the forecast-side winner remains Reactive sharp, but the deployed winner shifts as switching friction increases. The forecast-selected model becomes recurrently deployed-suboptimal at moderate and high friction}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Forecasting-native and operational corroboration. Traffic-Hourly provides a second forecasting-native task family, while inventory provides operational corroboration. Both show that forecast-side winners can become deployed-suboptimal under fixed interfaces at moderate-to-high friction.}}{2}{table.2}\protected@file@percent }
\newlabel{tab:q2-corroboration-compact}{{2}{2}{Forecasting-native and operational corroboration. Traffic-Hourly provides a second forecasting-native task family, while inventory provides operational corroboration. Both show that forecast-side winners can become deployed-suboptimal under fixed interfaces at moderate-to-high friction}{table.2}{}}
